+{% if mode == "auto" -%}
+{% if tokenizer_version < 7 -%}
+body: content | fcalls
+{% else -%}
+body: content | (content? fcalls)
+{% endif -%}
+fcalls: {{ fcall }}
+{% elif mode == "required" -%}
+body: content? fcalls
+fcalls: {{ fcall }}
+{% elif mode == "none" -%}
+body: content
+{% endif -%}
+{% if tokenizer_version < 7 -%}
+content: /(.|\n)+/
+{% else -%}
+content: (/(.|\n)+/)+
