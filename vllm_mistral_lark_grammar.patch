+
+OPTIONAL_THINK_LARK_GRAMMAR = r"""start: body
+{% if mode == "auto" -%}
+body: think? (content | fcalls)
+fcalls: content? {{ fcall }}
+{% elif mode == "required" -%}
+body: think? fcalls
+fcalls: content? {{ fcall }}
+{% elif mode == "none" -%}
+body: think? content
+{% endif -%}
